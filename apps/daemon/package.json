{
  "name": "@openvideo/daemon",
  "version": "0.0.0",
  "private": true,
  "description": "OpenVideo daemon: the single privileged process. node:http + SSE host that scaffolds workspaces and spawns headless Claude Code sessions in them (ADR-0014).",
  "type": "module",
  "bin": {
    "openvideo-daemon": "src/server.ts"
  },
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@openvideo/render": "workspace:*",
    "@openvideo/installer": "workspace:*",
    "@openvideo/cli-adapter": "workspace:*",
    "@openvideo/workspace-template": "workspace:*",
    "@openvideo/shared": "workspace:*",
    "@openvideo/transcribe": "workspace:*"
  },
  "license": "Apache-2.0"
}
